# ── Copy this to .env and fill in your values ──
# cp .env.example .env   (Mac/Linux)
# copy .env.example .env  (Windows)

# ── LLM Option A: Claude API (best quality) ───────────────────
# Get a free key at: https://console.anthropic.com/
# Leave blank if using Ollama instead
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use
# claude-3-5-haiku-20241022  → fastest, cheapest (~$0.001/query)
# claude-3-5-sonnet-20241022 → smarter, slightly more expensive
CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── LLM Option B: Ollama (free, fully local, no account needed) ─
# Install Ollama from: https://ollama.com
# Then run: ollama pull llama3.2
# Then run: ollama serve
# The app auto-detects Ollama if it is running
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── PubMed API (always free, just needs a real email) ─────────
ENTREZ_EMAIL=yourname@email.com

# ── Settings ──────────────────────────────────────────────────
RETRIEVAL_K=8

# ── Local paths (no need to change) ──────────────────────────
CHROMA_DIR=./chroma_db
DATA_DIR=./data
OUTPUT_DIR=./outputs
