# ── Copy this to .env and fill in your values ──
# cp .env.example .env

# Anthropic Claude API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use
# claude-3-5-haiku-20241022  → fastest, cheapest (~$0.001/query)
# claude-3-5-sonnet-20241022 → smarter, slightly more expensive
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Your email for NCBI PubMed API (required, use real email)
ENTREZ_EMAIL=yourname@email.com

# Number of chunks to retrieve per query (more = richer context, slower)
RETRIEVAL_K=8

# Local paths (no need to change)
CHROMA_DIR=./chroma_db
DATA_DIR=./data
OUTPUT_DIR=./outputs
